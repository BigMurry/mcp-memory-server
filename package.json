{
  "name": "mcp-memory-server",
  "version": "1.0.0",
  "description": "MCP memory server for persistent agent memory with SQLite",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "init-db": "tsx scripts/init-db.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
